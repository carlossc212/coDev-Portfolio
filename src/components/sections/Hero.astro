---
import { Image } from "astro:assets"
import { GradientNoFillText } from "@components/text"
import codePNG from "@images/code.png"
import CVButton from "@components/CVButton.astro"
import { Fade } from "@components/effects"
---
<section class="container hero">
    <div class="row">
        <div class="col-12 col-lg-6">
            <p class="hello">👋 Hello! I'm</p>
            <h1 class="hero-title">Carlos Sanjuan</h1>
            <h2 class="hero-subtitle text-primary mb-4">
                <GradientNoFillText>Software Developer</GradientNoFillText>
            </h2>
            <Fade>
                <p class="description">
                    Transform your ideas into powerful digital experiences that
                    captivate and convert. We can make it happen together!
                </p>
            </Fade>
            
            <Fade from="bottom">
                <CVButton class="cv-button"/>
            </Fade>
            
        </div>
        <div class="col-12 col-lg-6 mt-5 mt-lg-0 d-flex align-items-center justify-content-center">
            <Fade>
                <Image src={codePNG} alt={"Programming"} loading={"eager"} class={"img-fluid levite"}/>
            </Fade>
        </div>
    </div>
</section>

<style>
    .hero {
        padding-top: 280px;
        min-height: 100vh;
    }

    .hello {
        font-size: 1.5rem;
        margin: 0;
        padding-left: 5px;
    }

    .hero-title {
        font-size: 5rem;
    }

    .hero-subtitle {
        font-size: 3rem;
    }

    .description {
        padding-right: 30%;
        font-size: 1.2rem;
    }

    .cv-button{
        margin-top: 20px;
    }

    .levite{
        animation: levite 3s ease-in-out infinite;
    }

    @keyframes levite{
        0%{
            transform: translateY(-10px);
        }

        50%{
            transform: translateY(10px);
        }

        100%{
            transform: translateY(-10px);
        }
    }

    @media screen and (max-width:767px) {
        .hero {
            padding-top: 150px;
        }
    }
</style>


