---
import { Image } from "astro:assets"
import GradientNoFillText from "./text/GradientNoFillText.astro"
import codePNG from "../images/code.png"
import CVButton from "./CVButton.astro"
---
<section class="container hero">
    <div class="row">
        <div class="col-12 col-md-6">
            <p class="hello">Hello! I'm</p>
            <h1 class="hero-title">Carlos Sanjuan</h1>
            <h2 class="hero-subtitle text-primary mb-4">
                <GradientNoFillText>Software Developer</GradientNoFillText>
            </h2>
            <p class="description">
                Transform your ideas into powerful digital experiences that
                captivate and convert. We can make it happen together!
            </p>
            <CVButton/>
        </div>
        <div class="col-12 col-md-6 align-items-center">
            <Image src={codePNG} alt={"Programming"} loading={"eager"} class={"img-fluid"}>
        </div>
    </div>
</section>

<style>
    .hero {
        padding-top: 280px;
        min-height: 100vh;
    }

    .hello {
        font-size: 1.5rem;
        margin: 0;
        padding-left: 5px;
    }

    .hero-title {
        font-size: 5rem;
    }

    .hero-subtitle {
        font-size: 3rem;
    }

    .description {
        padding-right: 30%;
        font-size: 1.2rem;
    }

    .cv-button{
        margin-top: 20px;
    }

    @media screen and (max-width:767px) {
        .hero {
            padding-top: 150px;
        }
    }
</style>


